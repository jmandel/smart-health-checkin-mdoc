<?xml version="1.0" encoding="utf-8"?>
<!--
  SMART starburst, cropped to 5 colored wedges (no wordmark, no detached blue
  bottom triangle). Source: wallet-android/app/matcher/assets/starburst.svg, which is in turn
  derived from https://smarthealthit.org/wp-content/themes/SMART/images/logo.svg

  Adaptive icon viewport is 108x108. The starburst is scaled into the inner
  ~66x66 safe zone so it survives any OEM mask shape.

  The original starburst's bbox center is (104.66, 36.39) in the SVG
  coordinate system; the inner translate moves that center to (0, 0), the
  middle group scales 95.17 → 66 (factor 0.6935), and the outer group lifts
  the result to the viewport center (54, 54).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <group
        android:translateX="54"
        android:translateY="54">
        <group
            android:scaleX="0.6935"
            android:scaleY="0.6935">
            <group
                android:translateX="-104.66"
                android:translateY="-36.39">

                <path
                    android:fillColor="#722772"
                    android:pathData="M83.91,0 L93.42,0 L104.56,18.47 L116.03,0 L125.28,0 L104.58,33.96 Z" />
                <path
                    android:fillColor="#E24A31"
                    android:pathData="M60.61,35.72 L65.37,28.16 L87.76,28.16 L76.67,9.49 L81.3,1.87 L101.89,35.72 Z" />
                <path
                    android:fillColor="#89BF44"
                    android:pathData="M148.72,38.78 L143.97,46.33 L121.57,46.33 L132.66,65.16 L128.03,72.78 L107.44,38.78 Z" />
                <path
                    android:fillColor="#E77D26"
                    android:pathData="M128,1.73 L132.76,9.55 L121.5,28.16 L144.06,28.16 L148.69,35.72 L107.4,35.72 Z" />
                <path
                    android:fillColor="#F1B42A"
                    android:pathData="M81.28,72.77 L76.53,64.94 L87.78,46.33 L65.23,46.33 L60.6,38.78 L101.89,38.78 Z" />

            </group>
        </group>
    </group>
</vector>
